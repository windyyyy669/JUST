<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>문명 재건 — Dr.STONE 스타일</title>
<style>
/* ── BASIC RESET & GRAPHIC STYLE ── */
* { box-sizing: border-box; margin: 0; padding: 0; cursor: default; }
html, body { width: 100%; height: 100%; overflow: hidden; font-family: 'Malgun Gothic', 'Apple SD Gothic Neo', sans-serif; background: #080808; color: #f0f0f0; }

/* ── LAYOUT ── */
#ui-root { display: grid; grid-template-columns: 240px 1fr 280px; grid-template-rows: 60px 1fr 180px; width: 100vw; height: 100vh; }

/* ── TOP BAR (RESOURCE ICON STYLE) ── */
#topbar {
  grid-column: 1 / 4; grid-row: 1;
  background: linear-gradient(180deg, #151515 0%, #101010 100%); border-bottom: 2px solid #2a2a2a;
  display: flex; align-items: center; gap: 25px; padding: 0 20px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.5); z-index: 10;
}
.game-title { font-size: 18px; font-weight: 800; color: #c8e6a0; text-shadow: 0 0 10px rgba(160,220,100,0.5); letter-spacing: 1px; }
.res-group { display: flex; gap: 18px; flex: 1; justify-content: center;}
.res-chip { font-size: 14px; color: #ccc; display: flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.05); padding: 5px 10px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); }
.res-chip span { font-weight: 700; font-size: 16px; color: #fff; }

/* Inline SVG Icons for Resources */
.icon { width: 20px; height: 20px; fill: currentColor; }
.res-chip.stone { color: #aaa; }
.res-chip.wood  { color: #8cb870; }
.res-chip.fuel  { color: #f09040; }
.res-chip.ore   span { color: #90ccf0; }
.res-chip.power span { color: #aaddff; }

/* ── LEFT PANEL (UNITS & STATS) ── */
#left-panel {
  grid-column: 1; grid-row: 2 / 4;
  background: rgba(20, 20, 20, 0.9); border-right: 2px solid #222;
  display: flex; flex-direction: column; overflow: hidden; z-index: 5;
}
.panel-section { padding: 15px; border-bottom: 1px solid #252525; }
.panel-title { font-size: 12px; color: #666; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 10px; font-weight: 700;}

.stat-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.stat-label { font-size: 12px; color: #999; width: 45px; flex-shrink: 0; }
.stat-bar { flex: 1; height: 6px; background: #111; border-radius: 3px; overflow: hidden; border: 1px solid #333;}
.stat-fill { height: 100%; border-radius: 3px; transition: width 0.4s ease-out; box-shadow: 0 0 5px currentColor;}
.stat-val { font-size: 12px; color: #fff; width: 30px; text-align: right; font-weight: 700;}

/* unit list */
#unit-list { flex: 1; overflow-y: auto; padding: 10px; }
.unit-item { display: flex; align-items: center; gap: 10px; padding: 8px; border-radius: 8px; cursor: pointer; transition: background 0.2s; margin-bottom: 5px; border: 1px solid transparent; }
.unit-item:hover { background: rgba(255,255,255,0.05); }
.unit-item.selected { background: rgba(160,220,100,0.15); border-color: rgba(160,220,100,0.3); }
.unit-icon { width: 32px; height: 32px; border-radius: 50%; border: 2px solid; flex-shrink: 0; background-size: cover; background-position: center;}
.unit-info { flex: 1; }
.unit-name { font-size: 14px; color: #fff; font-weight: 600; }
.unit-meta { font-size: 11px; color: #888; display: flex; justify-content: space-between; }
.unit-hp-bar { width: 100%; height: 4px; background: #111; border-radius: 2px; margin-top: 3px; overflow: hidden; }
.unit-hp-fill { height: 100%; transition: width 0.3s; }

#tick-btn {
  margin: 15px; padding: 12px; border-radius: 8px;
  background: #2a4a1a; border: none;
  color: #c8e6a0; font-size: 15px; font-weight: 800;
  cursor: pointer; transition: all 0.2s; letter-spacing: 1px; text-transform: uppercase;
  box-shadow: 0 4px 0 #1a3010;
}
#tick-btn:hover { background: #355a20; transform: translateY(-1px); }
#tick-btn:active { transform: translateY(2px); box-shadow: 0 1px 0 #1a3010;}

/* ── MAP (HIGH GRAPHIC TERRAIN) ── */
#map-wrap {
  grid-column: 2; grid-row: 2;
  position: relative; overflow: hidden; cursor: crosshair;
}
#map-canvas { display: block; width: 100%; height: 100%; }

/* ── RIGHT PANEL (TECH TREE WITH ICON) ── */
#right-panel {
  grid-column: 3; grid-row: 2 / 4;
  background: rgba(20, 20, 20, 0.9); border-left: 2px solid #222;
  display: flex; flex-direction: column; overflow: hidden; z-index: 5;
}
.right-tabs { display: flex; border-bottom: 1px solid #252525; }
.rtab { flex: 1; padding: 12px; font-size: 12px; font-weight: 700; text-align: center; cursor: pointer; color: #666; border: none; background: none; transition: all 0.2s; text-transform: uppercase; letter-spacing: 1px;}
.rtab.active { color: #c8e6a0; background: rgba(255,255,255,0.03); box-shadow: inset 0 -2px 0 #6a9e50;}

.rtab-content { display: none; flex: 1; overflow-y: auto; padding: 15px; }
.rtab-content.active { display: block; }

/* tech cards */
.tech-era { font-size: 11px; color: #555; letter-spacing: 2px; text-transform: uppercase; margin: 15px 0 8px; font-weight: 800; border-bottom: 1px solid #222; padding-bottom: 3px;}
.tech-card {
  background: rgba(40,40,40,0.5); border: 1px solid #333; border-radius: 8px;
  padding: 10px; margin-bottom: 8px; cursor: pointer; transition: all 0.2s;
  display: flex; gap: 10px; align-items: center;
}
.tech-card:hover:not(.locked):not(.done) { border-color: #5a9e4a; background: rgba(60,100,50,0.2); transform: translateX(3px);}
.tech-card.done { border-color: #3a5a2a; background: rgba(20,40,15,0.3); opacity: 0.8; }
.tech-card.locked { opacity: 0.3; cursor: not-allowed; }
.tech-card.active-research { border-color: #4a8acc; background: rgba(15,30,50,0.4); box-shadow: 0 0 10px rgba(74,138,204,0.3); }

.tech-icon { width: 36px; height: 36px; border-radius: 6px; background-color: #111; border: 1px solid #333; flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: #555;}
.tech-card.done .tech-icon { color: #6a9e50; border-color: #3a5a2a;}
.tech-card.active-research .tech-icon { color: #4a8acc; border-color: #3a4a60;}

.tc-info { flex: 1; }
.tc-head { display: flex; align-items: center; gap: 5px; margin-bottom: 2px; }
.tc-name { font-size: 13px; font-weight: 700; color: #fff; }
.tc-formula { font-size: 10px; color: #5a9acc; font-family: 'Courier New', monospace; font-weight: 700;}
.prog-bar { height: 3px; background: #1e3050; border-radius: 1.5px; margin-top: 5px; overflow: hidden; border: 1px solid #333;}
.prog-fill { height: 100%; background: #4a8acc; box-shadow: 0 0 5px #4a8acc; transition: width 0.3s; }

/* ── BOTTOM LOG ── */
#bottom-log {
  grid-column: 2; grid-row: 3;
  background: #0a0a0a; border-top: 2px solid #222;
  padding: 10px 15px; overflow-y: auto; display: flex; flex-direction: column-reverse; gap: 4px;
}
.log-line { font-size: 12px; color: #777; line-height: 1.5; font-weight: 500;}
.log-line.success { color: #8cb870; }
.log-line.warn { color: #f0a050; }
.log-line.event { color: #a080f0; }

</style>
</head>
<body>
<div id="ui-root">

  <div id="topbar">
    <div class="game-title">DR.STONE: REBOOT</div>
    <div class="res-group">
      <div class="res-chip stone">
        <svg class="icon" viewBox="0 0 24 24"><path d="M12 2l-8 6 2 10h12l2-10-8-6z"/></svg>
        <span id="r-stone">120</span>
      </div>
      <div class="res-chip wood">
        <svg class="icon" viewBox="0 0 24 24"><path d="M3 18v-2h18v2H3zm0-4v-2h18v2H3zm0-4V8h18v2H3zm0-4V2h18v2H3z"/></svg>
        <span id="r-wood">80</span>
      </div>
      <div class="res-chip fuel">
        <svg class="icon" viewBox="0 0 24 24"><path d="M18 16c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm2-10V4h-3V2h-2v2h-3v2h3v12c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-6-2l-1.41 1.41L11 2.83V16c0 2.76 2.24 5 5 5s5-2.24 5-5V4h-7z"/></svg>
        <span id="r-fuel">40</span>
      </div>
      <div class="res-chip ore">
        <svg class="icon" viewBox="0 0 24 24"><path d="M12 2l-10 7 3.5 13h13L22 9l-10-7zm0 15.5l-3.5-2.5 1-4 3.5-1.5 3.5 1.5 1 4-3.5 2.5z"/></svg>
        <span id="r-ore">0</span>
      </div>
    </div>
  </div>

  <div id="left-panel">
    <div class="panel-section">
      <div class="panel-title">Survival Stats</div>
      <div class="stat-row">
        <div class="stat-label">Survival</div>
        <div class="stat-bar"><div class="stat-fill" id="bar-survival" style="width:70%;color:#cc6655;background:#cc6655;"></div></div>
        <div class="stat-val" id="val-survival">70</div>
      </div>
      <div class="stat-row">
        <div class="stat-label">Food</div>
        <div class="stat-bar"><div class="stat-fill" id="bar-food" style="width:55%;color:#aa8833;background:#aa8833;"></div></div>
        <div class="stat-val" id="val-food">55</div>
      </div>
    </div>
    <div class="panel-title" style="padding:15px 15px 5px;">Exploration Team</div>
    <div id="unit-list"></div>
    <button id="tick-btn" onclick="nextDay()">▶ Day Pass</button>
  </div>

  <div id="map-wrap">
    <canvas id="map-canvas"></canvas>
  </div>

  <div id="right-panel">
    <div class="right-tabs">
      <button class="rtab active" onclick="switchRTab('tech',this)">Tech Tree</button>
      <button class="rtab" onclick="switchRTab('chem',this)">Dictionary</button>
    </div>
    <div id="rtab-tech" class="rtab-content active"></div>
    <div id="rtab-chem" class="rtab-content">
      <div style="color:#555;font-size:12px;padding:20px;text-align:center;line-height:1.6;">Research technology to unlock chemical formulas and knowledge.</div>
    </div>
  </div>

  <div id="bottom-log">
    <div class="log-line">The reconstruction has begun. Explore the world from elements.</div>
  </div>

</div>

<script>
// ═══════════════════════════════════════════
//  WORLD GENERATION (HIGHER RESOLUTION FEEL)
// ═══════════════════════════════════════════
const WORLD_W = 160, WORLD_H = 110;
let heightMap = [], moistureMap = [], resourceMap = [];

function noise(x, y, seed) {
  const s = Math.sin(x * 127.1 + y * 311.7 + seed) * 43758.5453;
  return s - Math.floor(s);
}

function smoothNoise(x, y, seed, scale) {
  const xi = x / scale, yi = y / scale;
  const x0 = Math.floor(xi), y0 = Math.floor(yi);
  const fx = xi - x0, fy = yi - y0;
  const n00 = noise(x0, y0, seed), n10 = noise(x0+1, y0, seed);
  const n01 = noise(x0, y0+1, seed), n11 = noise(x0+1, y0+1, seed);
  const sx = fx*fx*(3-2*fx), sy = fy*fy*(3-2*fy);
  return n00 + (n10-n00)*sx + (n01-n00)*sy + (n00-n10-n01+n11)*sx*sy;
}

function fbm(x, y, seed, octaves, scale) {
  let v=0, amp=1, tot=0, sc=scale;
  for (let i=0; i<octaves; i++) { v += smoothNoise(x,y,seed+i*100,sc)*amp; tot+=amp; amp*=0.5; sc*=0.5; }
  return v/tot;
}

function generateWorld() {
  const cx = WORLD_W/2, cy = WORLD_H/2;
  const seed1 = Math.random()*999, seed2 = Math.random()*999+500;
  for (let y=0; y<WORLD_H; y++) {
    heightMap[y]=[]; moistureMap[y]=[]; resourceMap[y]=[];
    for (let x=0; x<WORLD_W; x++) {
      const h = fbm(x,y,seed1,6,40);
      const dist = Math.sqrt((x-cx)**2+(y-cy)**2) / (Math.min(cx,cy)*0.9);
      heightMap[y][x] = Math.max(0, h - dist*0.35);
      moistureMap[y][x] = fbm(x,y,seed2,4,30);
      resourceMap[y][x] = null;
    }
  }
  // scatter resources
  const types = ['stone','wood','ore','fuel'];
  const counts = {stone:40,wood:50,ore:18,fuel:12};
  types.forEach(t => {
    let placed=0;
    while(placed < counts[t]) {
      const rx = Math.floor(Math.random()*WORLD_W);
      const ry = Math.floor(Math.random()*WORLD_H);
      const h = heightMap[ry][rx];
      const m = moistureMap[ry][rx];
      let ok = false;
      if (t==='stone' && h>0.35 && h<0.75) ok=true;
      if (t==='wood'  && h>0.32 && h<0.62 && m>0.4) ok=true;
      if (t==='ore'   && h>0.5) ok=true;
      if (t==='fuel'  && h>0.28 && h<0.50 && m>0.5) ok=true;
      if (ok && !resourceMap[ry][rx]) { resourceMap[ry][rx]={type:t, amount:Math.floor(Math.random()*30+15)}; placed++; }
    }
  });
}

const BIOME_COLOR = {
  water:     ['#1a3a5c', '#152d48'], // Light/Dark for terrain texture
  shore:     ['#c8b87a', '#b0a065'],
  plains:    ['#8aaa60', '#759550'],
  grassland: '#5a8840',
  forest:    '#2d5a28',
  highland:  '#7a7060',
  mountain:  ['#9a9898', '#757575'],
};

const RES_COLOR = { stone:'#ffffff', wood:'#a06030', ore:'#6090c0', fuel:'#f09040' };

// ═══════════════════════════════════════════
//  GAME STATE
// ═══════════════════════════════════════════
let state = {
  day: 1,
  res: { stone:120, wood:80, fuel:40, ore:0, power:0 },
  stats: { survival:70, food:55, knowledge:10, industry:5 },
  unlocked: new Set(),
  researching: null, researchProg: 0, researchTarget: 3,
  selectedUnit: null,
};

// units
let units = [];
function spawnUnits() {
  const names = ['Senku','Taiju','Yuzuriha','Chrome','Kohaku','Ginro'];
  const colors = ['#e06060','#60a0e0','#e0c060','#80cc70','#cc80d0','#e09050'];
  const cx = WORLD_W/2, cy = WORLD_H/2;
  for (let i=0; i<6; i++) {
    units.push({
      id:i, name:names[i], color:colors[i],
      wx: cx + (Math.random()-0.5)*8,
      wy: cy + (Math.random()-0.5)*8,
      tx: null, ty: null,
      state: 'idle', hp: 90+Math.floor(Math.random()*10), maxHp:100,
      carrying: null, carryAmt: 0
    });
  }
}

// ═══════════════════════════════════════════
//  TECH TREE (SIMPLIFIED FOR GRAPHIC VIEW)
// ═══════════════════════════════════════════
const TECHS = [
  {id:'fire',  era:1, name:'Fire Making',      formula:'C + O₂ → CO₂ + Heat', costs:{stone:20,wood:30}},
  {id:'clay',  era:1, name:'Pottery',          formula:'SiO₂·Al₂O₃ → Hard Ceramic', costs:{stone:10,wood:20}, req:['fire']},
  {id:'charcoal',era:1,name:'Charcoal',        formula:'Biomass → Pyrolysis → C', costs:{wood:50}, req:['fire']},
  {id:'copper',era:2, name:'Copper Smelting',  formula:'Cu₂O + C → 2Cu + CO₂', costs:{ore:20,fuel:30}, req:['charcoal']},
  {id:'iron',  era:2, name:'Iron Smelting',    formula:'Fe₂O₃ + 3CO → 2Fe + 3CO₂', costs:{ore:50,fuel:60}, req:['copper']},
];

// ═══════════════════════════════════════════
//  CANVAS RENDERER (TERRAIN & VISUAL EFFECTS)
// ═══════════════════════════════════════════
const canvas = document.getElementById('map-canvas');
const ctx = canvas.getContext('2d');
let TW = 1, TH = 1;
let camX = 0, camY = 0, zoom = 7;
let mapImageData = null;

function resizeCanvas() {
  const wrap = document.getElementById('map-wrap');
  canvas.width = wrap.clientWidth;
  canvas.height = wrap.clientHeight;
  renderMap();
}

function worldToScreen(wx, wy) {
  return { x: (wx - camX) * zoom, y: (wy - camY) * zoom };
}

function bakeMapImage() {
  const offscreen = document.createElement('canvas');
  offscreen.width = WORLD_W * zoom;
  offscreen.height = WORLD_H * zoom;
  const oc = offscreen.getContext('2d');

  for (let y=0; y<WORLD_H; y++) {
    for (let x=0; x<WORLD_W; x++) {
      const h = heightMap[y][x], m = moistureMap[y][x];
      const biome = getBiome(h, m);
      let col = BIOME_COLOR[biome];
      
      // Terrain Texture (Dithering effect for graphic feel)
      if (Array.isArray(col)) col = (x+y)%2===0 ? col[0] : col[1];
      
      const shade = 0.85 + h * 0.3; // Height shading
      oc.fillStyle = shadeHex(col, shade);
      oc.fillRect(x*zoom, y*zoom, zoom, zoom);
    }
  }
  mapImageData = offscreen;
}

function shadeHex(hex, factor) {
  let r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  r = Math.min(255,Math.round(r*factor)); g = Math.min(255,Math.round(g*factor)); b = Math.min(255,Math.round(b*factor));
  return `rgb(${r},${g},${b})`;
}

function getBiome(h, m) {
  if (h < 0.28) return 'water'; if (h < 0.32) return 'shore';
  if (h > 0.78) return 'mountain';
  if (m > 0.62) return 'forest'; if (m > 0.42) return 'grassland';
  return 'plains';
}

// Visual Effects State
let particleEffects = []; // {x, y, tx, ty, color, timer}

function renderMap() {
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0,0,W,H);

  // draw baked terrain
  if (mapImageData) ctx.drawImage(mapImageData, -camX*zoom, -camY*zoom);

  // draw resources (Glow effect)
  ctx.shadowBlur = 10;
  for (let y=0; y<WORLD_H; y++) {
    for (let x=0; x<WORLD_W; x++) {
      const r = resourceMap[y][x];
      if (!r || r.amount <= 0) continue;
      const s = worldToScreen(x+0.5, y+0.5);
      if (s.x<-zoom||s.x>W+zoom||s.y<-zoom||s.y>H+zoom) continue;
      
      ctx.fillStyle = RES_COLOR[r.type];
      ctx.shadowColor = RES_COLOR[r.type];
      ctx.beginPath(); ctx.arc(s.x,s.y,zoom/3,0,Math.PI*2); ctx.fill();
    }
  }
  ctx.shadowBlur = 0; // reset

  // draw base camp (Graphic Marker)
  const baseS = worldToScreen(WORLD_W/2, WORLD_H/2);
  ctx.fillStyle = '#ffc020'; ctx.strokeStyle = '#fff'; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(baseS.x, baseS.y-8); ctx.lineTo(baseS.x+6, baseS.y+4); ctx.lineTo(baseS.x-6, baseS.y+4); ctx.closePath(); ctx.fill(); ctx.stroke();

  // draw units (RPG Style dot with outline)
  units.forEach(u => {
    const s = worldToScreen(u.wx, u.wy);
    if (s.x<-10||s.x>W+10||s.y<-10||s.y>H+10) return;
    const selected = state.selectedUnit === u.id;

    if (selected) {
      // Selection Ring Effect
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 1.5; ctx.setLineDash([2,2]);
      ctx.beginPath(); ctx.arc(s.x,s.y,9,0,Math.PI*2); ctx.stroke(); ctx.setLineDash([]);
    }

    ctx.fillStyle = u.color; ctx.strokeStyle = selected ? '#fff' : '#000'; ctx.lineWidth = selected ? 2 : 1;
    ctx.beginPath(); ctx.arc(s.x,s.y,5,0,Math.PI*2); ctx.fill(); ctx.stroke();

    // hp pip
    const hpFrac = u.hp / u.maxHp;
    ctx.fillStyle = '#222'; ctx.fillRect(s.x-5, s.y+7, 10, 2);
    ctx.fillStyle = hpFrac>0.5 ? '#8cb870' : '#cc4433'; ctx.fillRect(s.x-5, s.y+7, 10*hpFrac, 2);
  });

  // Render Visual Effects (Resource flying to base)
  for(let i = particleEffects.length -1; i>=0; i--) {
    const p = particleEffects[i];
    p.timer += 0.05;
    const curX = p.x + (p.tx - p.x) * p.timer;
    const curY = p.y + (p.ty - p.y) * p.timer - Math.sin(p.timer * Math.PI) * 20; // Arc movement
    const s = worldToScreen(curX, curY);

    ctx.fillStyle = p.color; ctx.shadowColor = p.color; ctx.shadowBlur = 8;
    ctx.beginPath(); ctx.arc(s.x, s.y, 3, 0, Math.PI*2); ctx.fill();
    ctx.shadowBlur = 0;

    if(p.timer >= 1) particleEffects.splice(i, 1);
  }
}

// ═══════════════════════════════════════════
//  UNIT AI & UI UPDATES
// ═══════════════════════════════════════════
function tickUnits() {
  units.forEach(u => {
    if (u.tx !== null) {
      const dx = u.tx - u.wx, dy = u.ty - u.wy;
      const dist = Math.sqrt(dx*dx+dy*dy);
      const speed = 0.9;
      if (dist < speed) {
        u.wx = u.tx; u.wy = u.ty;
        arriveAt(u);
      } else { u.wx += dx/dist * speed; u.wy += dy/dist * speed; }
    } else {
      // random wander
      if (Math.random() < 0.1) {
        const ang = Math.random() * Math.PI*2, r = Math.random() * 12 + 2;
        u.tx = Math.max(1, Math.min(WORLD_W-1, WORLD_W/2 + Math.cos(ang)*r));
        u.ty = Math.max(1, Math.min(WORLD_H-1, WORLD_H/2 + Math.sin(ang)*r));
      }
    }
  });
}

function arriveAt(u) {
  const gx = Math.floor(u.wx), gy = Math.floor(u.wy);
  const res = resourceMap[gy] && resourceMap[gy][gx];
  if (res && res.amount > 0) {
    const harvest = Math.min(res.amount, 5);
    state.res[res.type] += harvest; res.amount -= harvest;
    addLog(`${u.name} collected ${resLabel(res.type)} +${harvest}.`, 'success');
    
    // Trigger Visual Effect
    particleEffects.push({
      x: u.wx, y: u.wy, tx: WORLD_W/2, ty: WORLD_H/2,
      color: RES_COLOR[res.type], timer: 0
    });
  }
  u.tx = null; u.ty = null;
}

function resLabel(t) { return {stone:'Stone',wood:'Wood',fuel:'Fuel',ore:'Ore'}[t]||t; }

// Click to Select/Move
canvas.addEventListener('mousedown', e => {
  const rect = canvas.getBoundingClientRect();
  const sx = e.clientX - rect.left, sy = e.clientY - rect.top;
  const w = { x: sx/zoom+camX, y: sy/zoom+camY };

  // check unit click
  let clicked = units.find(u => Math.sqrt((u.wx-w.x)**2+(u.wy-w.y)**2)*zoom < 10);
  if (clicked) {
    state.selectedUnit = clicked.id;
  } else if (state.selectedUnit !== null) {
    const u = units.find(u => u.id === state.selectedUnit);
    u.tx = w.x; u.ty = w.y;
  }
  updateUnitList();
});

function updateTopBar() {
  ['stone','wood','fuel','ore'].forEach(r => document.getElementById('r-'+r).textContent = state.res[r]);
  ['survival','food'].forEach(k => {
    document.getElementById('bar-'+k).style.width = state.stats[k]+'%';
    document.getElementById('val-'+k).textContent = state.stats[k];
  });
}

function updateUnitList() {
  const el = document.getElementById('unit-list'); el.innerHTML = '';
  units.forEach(u => {
    const div = document.createElement('div');
    div.className = 'unit-item' + (state.selectedUnit===u.id?' selected':'');
    div.innerHTML = `
      <div class="unit-icon" style="border-color:${u.color}; background-color:${u.color}33;"></div>
      <div class="unit-info">
        <div class="unit-name">${u.name}</div>
        <div class="unit-hp-bar"><div class="unit-hp-fill" style="width:${u.hp}%;background:${u.color}"></div></div>
      </div>
    `;
    div.onclick = ()=> { state.selectedUnit=u.id; updateUnitList(); };
    el.appendChild(div);
  });
}

function renderTechTree() {
  const el = document.getElementById('rtab-tech'); el.innerHTML = '';
  TECHS.forEach(t => {
    const done = state.unlocked.has(t.id);
    const locked = t.req && !t.req.every(r=>state.unlocked.has(r));
    let cls = 'tech-card';
    if (done) cls += ' done'; else if (locked) cls += ' locked';
    
    el.innerHTML += `<div class="${cls}">
      <div class="tech-icon">${done?'✓':'?'}</div>
      <div class="tc-info">
        <div class="tc-head"><span class="tc-name">${t.name}</span></div>
        <div class="tc-formula">${t.formula.split('→')[0]}</div>
      </div>
    </div>`;
  });
}

function addLog(msg, type) {
  const el = document.getElementById('bottom-log');
  const div = document.createElement('div'); div.className = 'log-line '+(type||''); div.textContent = msg;
  el.appendChild(div); if (el.children.length > 30) el.removeChild(el.firstChild);
}

// ═══════════════════════════════════════════
//  GAME LOOP
// ═══════════════════════════════════════════
function nextDay() {
  state.day++;
  tickUnits();
  // Simplified food consume
  state.stats.food = Math.max(0, state.stats.food - 3);
  updateTopBar(); updateUnitList(); addLog(`Day ${state.day} passed.`);
}

function animLoop() { renderMap(); requestAnimationFrame(animLoop); }

// ═══════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════
generateWorld(); spawnUnits(); resizeCanvas(); bakeMapImage();
camX = WORLD_W/2 - canvas.width/(zoom*2); camY = WORLD_H/2 - canvas.height/(zoom*2); // Center camera
updateTopBar(); updateUnitList(); renderTechTree(); animLoop();
window.addEventListener('resize', resizeCanvas);
</script>
</body>
</html>
